# Copy thành .env.local — sau khi sửa: bun run dev
# Production:
# API_URL=https://api-vcl.purintech.id.vn

# Local HTTPS (khuyến nghị): backend redirect HTTP → HTTPS
API_URL=https://localhost:7237

# Hoặc HTTP nếu backend tắt redirect HTTPS:
# API_URL=http://localhost:5209

# Bắt buộc cho SignalR (chat real-time) — trùng host với API_URL
# NEXT_PUBLIC_API_URL=https://localhost:7237

# Tắt thử kết nối SignalR (khi BE chưa deploy ChatHub)
# NEXT_PUBLIC_ENABLE_CHAT_HUB=false

# Nguồn dữ liệu FE: api (gọi backend) | mock (dữ liệu giả trong app)
# API test: admin@test.com / Admin123 (GET /api/Test/seed-admin)
# Mock login: sale@vcl.com (Sale), admin@vcl.com (Admin), ops@vcl.com (Ops), mật khẩu bất kỳ
NEXT_PUBLIC_DATA_SOURCE=mock

# Hoặc chỉ định hub đầy đủ (tùy chọn, thay cho NEXT_PUBLIC_API_URL)
# NEXT_PUBLIC_API_HUB_URL=https://localhost:7237/hubs/chat
