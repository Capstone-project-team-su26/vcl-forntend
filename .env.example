# Copy thành .env.local — sau khi sửa: bun run dev
# Production:
# API_URL=https://api-vcl.purintech.id.vn

# Local HTTPS (khuyến nghị): backend redirect HTTP → HTTPS
API_URL=https://localhost:7237

# Hoặc HTTP nếu backend tắt redirect HTTPS:
# API_URL=http://localhost:5209

# Bắt buộc cho SignalR (chat real-time) — trùng host với API_URL
# NEXT_PUBLIC_API_URL=https://localhost:7237

# Tắt thử kết nối SignalR (khi BE chưa deploy ChatHub)
# NEXT_PUBLIC_ENABLE_CHAT_HUB=false

# Nguồn dữ liệu FE: api (gọi backend HTTP) | mock (dữ liệu giả trong app)
# FE không kết nối DB — chỉ proxy /api/* tới API_URL.
# API test (dev): nút login — sales@test.com/Sales123, admin@test.com/Admin123, ops@test.com/Ops123
# (seed-staff / seed-admin; ops tạo qua Admin). Chỉ hiện khi NODE_ENV=development.
# Mock login: sale@vcl.com / admin@vcl.com / ops@vcl.com — mật khẩu bất kỳ (chỉ non-production)
# Production luôn ép API — NEXT_PUBLIC_DATA_SOURCE=mock bị bỏ qua.
NEXT_PUBLIC_DATA_SOURCE=mock

# Bắt buộc trên production (Vercel): secret ký cookie phiên HttpOnly.
# Local: có fallback dev; nên set sẵn để đồng bộ máy.
AUTH_COOKIE_SECRET=change-me-to-a-long-random-string

# Hoặc chỉ định hub đầy đủ (tùy chọn, thay cho NEXT_PUBLIC_API_URL)
# NEXT_PUBLIC_API_HUB_URL=https://localhost:7237/hubs/chat
